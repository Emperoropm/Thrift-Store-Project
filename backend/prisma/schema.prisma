generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
model User {
  id       Int     @id @default(autoincrement())
  name     String?
  email    String  @unique
  password String
  role     Role    @default(USER)
  photo    String? // 👈 Stores local file path (e.g., "/uploads/users/filename.jpg")
phone           String?  @unique   // e.g. "+9779841234567"
 phoneVerified   Boolean  @default(false)
 firebaseUid     String?  @unique
  products Product[]
  orders   Order[]   @relation("orders")

  notifications Notification[]

  dailyProductCount Int       @default(0)
  lastProductDate   DateTime?

  givenRatings    UserRating[] @relation("Reviewer")
  receivedRatings UserRating[] @relation("Seller")

conversations1 Conversation[] @relation("User1Conversation")
conversations2 Conversation[] @relation("User2Conversation")

sentMessages Message[] @relation("MessageSender")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Role {
  ADMIN
  USER
}

model Category {
  id       Int       @id @default(autoincrement())
  name     String    @unique
  products Product[]
}

model Product {
  id          Int           @id @default(autoincrement())
  title       String
  description String?
  price       Float
  quantity    Int           @default(1)
  images      String[]      // Store array of image URLs
  status      ProductStatus @default(PENDING)

  // New fields
  purchaseDate DateTime?     // When the seller purchased the item
  gender       String?       // MEN, WOMEN, UNISEX, KIDS
  refundable   Boolean       @default(true)
  location     Json?         // Store { address, lat, lng } as JSON

  rejectionReason String?

  categoryId Int?
  category   Category? @relation(fields: [categoryId], references: [id])

  sellerId Int
  seller   User @relation(fields: [sellerId], references: [id])

  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt

  orderItems OrderItem[]
}

enum ProductStatus {
  PENDING
  APPROVED
  REJECTED
  OUT_OF_STOCK
}

model Order {
  id        Int         @id @default(autoincrement())
  buyerId   Int
  buyer     User        @relation(fields: [buyerId], references: [id], name: "orders")
  total     Float
  items     OrderItem[]
  // 👇 NEW: Overall order status
  status    OrderStatus @default(PENDING)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  paymentStatus       PaymentStatus        @default(PENDING)
  paymentTransactions PaymentTransaction[]

  UserRating UserRating[]
}

enum OrderStatus {
  PENDING
  PROCESSING
  PARTIALLY_DELIVERED
  DELIVERED
  CANCELLED
}

model OrderItem {
  id              Int             @id @default(autoincrement())
  orderId         Int
  order           Order           @relation(fields: [orderId], references: [id])
  productId       Int
  product         Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity        Int
  price           Float
  // 👇 NEW: Delivery status fields
  status          OrderItemStatus @default(PENDING)
  cancelledReason String?
  deliveredAt     DateTime?
  updatedAt       DateTime        @updatedAt

  @@index([status])
  @@index([productId])
}

enum OrderItemStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  RECEIVED
  CANCELLED
}

// 👇 UPDATED: Fixed relation
model Notification {
  id        Int              @id @default(autoincrement())
  userId    Int
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  message   String
  read      Boolean          @default(false)
  metadata  Json? // Additional data like productId, adminId, etc.
  createdAt DateTime         @default(now())
}

enum NotificationType {
  PRODUCT_SUBMITTED
  PRODUCT_APPROVED
  PRODUCT_REJECTED
  PRODUCT_EDITED
  DAILY_LIMIT_REACHED
  // 👇 NEW: Order notifications
  ORDER_PLACED
  ORDER_STATUS_CHANGED
  ITEM_STATUS_CHANGED
}

model PaymentTransaction {
  id              Int           @id @default(autoincrement())
  orderId         Int
  order           Order         @relation(fields: [orderId], references: [id])
  transactionId   String        @unique
  transactionCode String?
  amount          Float
  status          PaymentStatus @default(PENDING)
  paymentMethod   String
  paymentData     String? // Store eSewa payment request data
  paymentResponse String? // Store eSewa response
  createdAt       DateTime      @default(now())
  completedAt     DateTime?

  @@index([orderId])
  @@index([transactionId])
  @@index([status])
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
}

model UserRating {
  id      Int     @id @default(autoincrement())
  score   Int // 1–5 stars
  comment String?

  reviewerId Int
  reviewer   User @relation("Reviewer", fields: [reviewerId], references: [id])

  sellerId Int
  seller   User @relation("Seller", fields: [sellerId], references: [id])

  orderId Int? // optional: rating linked to order
  order   Order? @relation(fields: [orderId], references: [id])

  createdAt DateTime @default(now())

  @@unique([reviewerId, sellerId, orderId])
}

model Conversation {
  id Int @id @default(autoincrement())

  user1Id Int
  user1 User @relation("User1Conversation", fields: [user1Id], references: [id])

  user2Id Int
  user2 User @relation("User2Conversation", fields: [user2Id], references: [id])

  messages Message[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([user1Id, user2Id])
}

model Message {
  id Int @id @default(autoincrement())

  conversationId Int
  conversation Conversation @relation(fields: [conversationId], references: [id])

  senderId Int
  sender User @relation("MessageSender", fields: [senderId], references: [id])

  content String
  read Boolean @default(false)

  createdAt DateTime @default(now())
}